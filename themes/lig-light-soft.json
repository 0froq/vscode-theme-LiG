  "tokenColors": [
    {
      "scope": [
        "entity.name.tag",
        "entity.other.attribute-name.directive",
        "meta.directive",
        "keyword.control.import",
        "keyword.control.export",
        "storage.type",
        "storage.modifier",
        "storage.type.class",
        "storage.type.interface",
        "storage.type.type"
      ],
      "settings": {
        "foreground": "#6aca9a"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "keyword.control.flow",
        "keyword.control.return",
        "keyword.control.throw",
        "keyword.control.trycatch",
        "storage.modifier.async",
        "storage.type.function.async",
        "punctuation.attribute-shorthand.bind"
      ],
      "settings": {
        "foreground": "#fa9a6a"
      }
    },
    {
      "scope": [
        "support.function.builtin",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#965c40"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language",
        "entity.name.constant",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#6a9afa"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "variable.language",
        "variable.parameter.function.language.special",
        "entity.name.type.interface",
        "entity.name.type.alias"
      ],
      "settings": {
        "foreground": "#405c96"
      }
    },
    {
      "scope": [
        "support.type.primitive",
        "support.type",
        "entity.name.type",
        "entity.name.class"
      ],
      "settings": {
        "foreground": "#a6c2fc"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "punctuation.definition.decorator"
      ],
      "settings": {
        "foreground": "#6aca9a"
      }
    },
    {
      "scope": [
        "variable.other.readwrite",
        "variable.other.object",
        "variable.other.constant",
        "constant.character"
      ],
      "settings": {
        "foreground": "#404040"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "meta.property-name",
        "variable.other.property",
        "support.variable.property",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#404040"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.operator.expression",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#404040"
      }
    },
    {
      "scope": [
        "string",
        "comment",
        "keyword.operator",
        "punctuation",
        "meta.brace",
        "delimiter"
      ],
      "settings": {
        "foreground": "#a1a1a1"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#0a0a0a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#404040",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#404040",
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.raw",
      "settings": {
        "foreground": "#404040"
      }
    }
  ],
